{
  "name": "@stereo/desktop",
  "productName": "Stereo",
  "version": "0.1.1",
  "private": true,
  "description": "Stereo desktop application.",
  "license": "MIT",
  "type": "module",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev --watch",
    "stereo": "electron-vite build && node scripts/run-stereo.cjs",
    "icons": "node scripts/generate-app-icons.cjs",
    "build": "electron-vite build",
    "package": "electron-vite build && pnpm dlx electron-builder@26.15.3 --publish never",
    "typecheck": "tsc --noEmit -p tsconfig.web.json && tsc --noEmit -p tsconfig.node.json"
  },
  "build": {
    "appId": "dev.getstereo.stereo",
    "productName": "Stereo",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "mac": {
      "icon": "resources/icon.icns",
      "category": "public.app-category.developer-tools",
      "identity": "-",
      "hardenedRuntime": false,
      "target": [
        "zip"
      ],
      "artifactName": "stereo-darwin-${arch}.${ext}"
    },
    "win": {
      "icon": "resources/icon.png",
      "target": [
        "zip"
      ],
      "artifactName": "stereo-windows-${arch}.${ext}"
    },
    "linux": {
      "icon": "resources/icon.png",
      "category": "Development",
      "target": [
        "tar.gz"
      ],
      "artifactName": "stereo-linux-${arch}.${ext}"
    },
    "extraResources": [
      {
        "from": "resources/icon.png",
        "to": "icon.png"
      },
      {
        "from": "../../LICENSE",
        "to": "LICENSE.txt"
      },
      {
        "from": "../../THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      }
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.209",
    "@stereo/core": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-vite": "^3.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  }
}
