#!/bin/sh
set -eu

REPOSITORY="samuelahmed/stereo"
RELEASE_BASE="https://github.com/$REPOSITORY/releases/latest/download"

fail() {
  printf 'stereo: %s\n' "$1" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || fail "required command not found: $1"
}

need curl

case "$(uname -s)" in
  Darwin) platform="darwin" ;;
  Linux) platform="linux" ;;
  *) fail "this installer supports macOS and Linux; use https://getstereo.com for Windows" ;;
esac

case "$(uname -m)" in
  arm64|aarch64) architecture="arm64" ;;
  x86_64|amd64) architecture="x64" ;;
  *) fail "unsupported architecture: $(uname -m)" ;;
esac

if [ "$platform" = "darwin" ]; then
  need unzip
  asset="stereo-darwin-$architecture.zip"
else
  need tar
  asset="stereo-linux-$architecture.tar.gz"
fi

temporary_directory="$(mktemp -d "${TMPDIR:-/tmp}/stereo-install.XXXXXX")"
archive="$temporary_directory/$asset"
checksums="$temporary_directory/SHA256SUMS"
staging="$temporary_directory/staging"

cleanup() {
  rm -rf "$temporary_directory"
}
trap cleanup EXIT
trap 'exit 1' HUP INT TERM

printf 'Downloading Stereo for %s %s…\n' "$platform" "$architecture"
curl -fL --retry 3 --proto '=https' --tlsv1.2 -o "$archive" "$RELEASE_BASE/$asset"
curl -fL --retry 3 --proto '=https' --tlsv1.2 -o "$checksums" "$RELEASE_BASE/SHA256SUMS"

expected="$(awk -v name="$asset" '$2 == name || $2 == "*" name { print $1; exit }' "$checksums")"
[ -n "$expected" ] || fail "the release does not contain a checksum for $asset"

if command -v shasum >/dev/null 2>&1; then
  actual="$(shasum -a 256 "$archive" | awk '{ print $1 }')"
elif command -v sha256sum >/dev/null 2>&1; then
  actual="$(sha256sum "$archive" | awk '{ print $1 }')"
else
  fail "a SHA-256 checksum tool is required"
fi

[ "$actual" = "$expected" ] || fail "checksum verification failed"
mkdir -p "$staging"

if [ "$platform" = "darwin" ]; then
  unzip -q "$archive" -d "$staging"
  source_app="$staging/Stereo.app"
  [ -d "$source_app" ] || fail "the macOS release did not contain Stereo.app"

  install_root="$HOME/Applications"
  destination="$install_root/Stereo.app"
  backup="$install_root/.Stereo.previous.$$"
  mkdir -p "$install_root"

  had_previous=false
  if [ -e "$destination" ]; then
    mv "$destination" "$backup"
    had_previous=true
  fi

  if mv "$source_app" "$destination"; then
    if [ "$had_previous" = true ]; then rm -rf "$backup"; fi
  else
    if [ "$had_previous" = true ]; then mv "$backup" "$destination"; fi
    fail "could not replace the existing application"
  fi

  printf 'Installed Stereo at %s\n' "$destination"
  open "$destination" >/dev/null 2>&1 || true
else
  tar -xzf "$archive" -C "$staging"
  source_directory="$staging"
  set -- "$staging"/*
  if [ "$#" -eq 1 ] && [ -d "$1" ]; then source_directory="$1"; fi

  executable_name=""
  for candidate in "$source_directory/stereo" "$source_directory/Stereo"; do
    if [ -f "$candidate" ]; then executable_name="$(basename "$candidate")"; break; fi
  done
  [ -n "$executable_name" ] || fail "the Linux release did not contain a Stereo executable"

  install_root="$HOME/.local/share"
  destination="$install_root/stereo"
  backup="$install_root/.stereo.previous.$$"
  mkdir -p "$install_root" "$HOME/.local/bin"

  had_previous=false
  if [ -e "$destination" ]; then
    mv "$destination" "$backup"
    had_previous=true
  fi

  if mv "$source_directory" "$destination"; then
    if [ "$had_previous" = true ]; then rm -rf "$backup"; fi
  else
    if [ "$had_previous" = true ]; then mv "$backup" "$destination"; fi
    fail "could not replace the existing application"
  fi

  executable="$destination/$executable_name"
  chmod +x "$executable"
  ln -sfn "$executable" "$HOME/.local/bin/stereo"
  printf 'Installed Stereo at %s\n' "$destination"
  printf 'Run it with %s\n' "$HOME/.local/bin/stereo"
fi

printf 'Verified against the checksums published with the GitHub release.\n'
